---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html class="scroll-smooth" lang="ja">
	<head>
		<BaseHead
			title={`About | ${SITE_TITLE}`}
			description="セキュリティ資格と法学学習を軸にしたエンジニアプロフィール"
		/>
	</head>
	<body class="bg-surface font-body text-on-surface overflow-x-hidden">
		<Header />

		<!-- About Hero -->
		<section class="pt-40 pb-28 px-8 bg-surface">
			<div class="max-w-7xl mx-auto">
				<span class="text-xs tracking-[0.2em] uppercase text-on-primary-container mb-4 block" style="font-family: var(--font-label)">About</span>
				<h1 class="text-5xl md:text-6xl leading-tight mb-8 text-primary max-w-3xl" style="font-family: var(--font-headline)">
					エンジニアリングを、より説明可能で強いものに。
				</h1>
				<p class="text-xl text-secondary max-w-2xl leading-relaxed mb-16">
					フルスタックエンジニアとして UI 実装から API・インフラまでを一気通貫で扱い、セキュリティを機能要件と同じ重みで初期設計から織り込むことを徹底しています。
				</p>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="bg-surface-container-low p-8 border border-outline-variant/10">
						<div class="w-10 h-10 flex items-center justify-center bg-secondary-container rounded-full mb-6">
							<span class="material-symbols-outlined text-on-secondary-container text-base">verified_user</span>
						</div>
						<h2 class="text-xl mb-3 text-primary" style="font-family: var(--font-headline)">資格と専門性</h2>
						<ul class="space-y-2 text-on-surface-variant text-sm">
							<li>情報処理安全確保支援士</li>
							<li>AWS Certified Security - Specialty</li>
							<li>Webアプリケーション 設計・開発・運用</li>
						</ul>
					</div>
					<div class="bg-surface-container-low p-8 border border-outline-variant/10">
						<div class="w-10 h-10 flex items-center justify-center bg-secondary-container rounded-full mb-6">
							<span class="material-symbols-outlined text-on-secondary-container text-base">gavel</span>
						</div>
						<h2 class="text-xl mb-3 text-primary" style="font-family: var(--font-headline)">リーガルマインドの活用</h2>
						<p class="text-on-surface-variant text-sm leading-relaxed">
							司法試験予備試験に向けて民事訴訟法を学習中。争点整理・主張責任・立証責任は、開発における要件境界設定と監査可能性の確保に直結します。
						</p>
					</div>
					<div class="bg-surface-container-low p-8 border border-outline-variant/10">
						<div class="w-10 h-10 flex items-center justify-center bg-secondary-container rounded-full mb-6">
							<span class="material-symbols-outlined text-on-secondary-container text-base">architecture</span>
						</div>
						<h2 class="text-xl mb-3 text-primary" style="font-family: var(--font-headline)">実装方針</h2>
						<ol class="list-decimal list-inside space-y-2 text-on-surface-variant text-sm">
							<li>脅威を前提に仕様を書く</li>
							<li>検証できるログと権限設計を行う</li>
							<li>法的・監査的な説明責任を意識して設計判断を残す</li>
						</ol>
					</div>
				</div>
			</div>
		</section>

		<!-- Specialization Section (dark) -->
		<section class="py-28 px-8 bg-primary text-on-primary">
			<div class="max-w-7xl mx-auto">
				<div class="mb-20">
					<span class="text-xs tracking-[0.2em] uppercase opacity-60 mb-4 block" style="font-family: var(--font-label)">Specialization</span>
					<h2 class="text-4xl" style="font-family: var(--font-headline)">複合知識の統合</h2>
				</div>
				<div class="grid grid-cols-1 md:grid-cols-3 gap-px bg-on-primary/10">
					<div class="bg-primary p-10">
						<div class="text-5xl mb-8 opacity-30 italic" style="font-family: var(--font-headline)">01</div>
						<h3 class="text-2xl mb-6" style="font-family: var(--font-headline)">デジタルフォレンジック</h3>
						<p class="opacity-70 leading-relaxed">
							登録セキスペとしての知見を活かし、ログの証拠能力・改ざん検知・監査証跡の設計まで、法的効力を持つシステムを構築します。
						</p>
					</div>
					<div class="bg-primary p-10">
						<div class="text-5xl mb-8 opacity-30 italic" style="font-family: var(--font-headline)">02</div>
						<h3 class="text-2xl mb-6" style="font-family: var(--font-headline)">会社法・内部統制</h3>
						<p class="opacity-70 leading-relaxed">
							会社法・内部統制の理解に基づき、権限管理・承認フロー・情報開示のシステム設計を適法かつ実用的に実装します。
						</p>
					</div>
					<div class="bg-primary p-10">
						<div class="text-5xl mb-8 opacity-30 italic" style="font-family: var(--font-headline)">03</div>
						<h3 class="text-2xl mb-6" style="font-family: var(--font-headline)">司法試験予備試験</h3>
						<p class="opacity-70 leading-relaxed">
							民事訴訟法の学習から得た「争点の明確化」「証明責任の分配」という思考は、仕様書のあいまい排除とテスト設計に直接応用しています。
						</p>
					</div>
				</div>
			</div>
		</section>

		<!-- Contact Section -->
		<section class="py-28 px-8 bg-surface-container-low" id="contact">
			<div class="max-w-7xl mx-auto">
				<div class="mb-16">
					<span class="text-xs tracking-[0.2em] uppercase text-on-primary-container mb-4 block" style="font-family: var(--font-label)">Contact</span>
					<h2 class="text-4xl text-primary" style="font-family: var(--font-headline)">お問い合わせ</h2>
				</div>
				<div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
					<div>
						<p class="text-on-surface-variant leading-relaxed mb-10 text-lg">
							プロジェクトのご相談、技術的な議論、あるいは単純に連絡を取りたい場合はお気軽にどうぞ。セキュリティ設計、法×ITの課題、大歓迎です。
						</p>
						<div class="space-y-6">
							<div class="flex items-center gap-4">
								<span class="material-symbols-outlined text-secondary">mail</span>
								<span class="text-on-surface-variant text-sm">フォームからメッセージをお送りください</span>
							</div>
							<div class="flex items-center gap-4">
								<span class="material-symbols-outlined text-secondary">schedule</span>
								<span class="text-on-surface-variant text-sm">通常 2 営業日以内にご返信します</span>
							</div>
						</div>
					</div>
					<form class="space-y-6" action="#" method="POST" novalidate>
						<div>
							<label class="block text-xs tracking-widest uppercase text-on-surface-variant mb-2" for="name" style="font-family: var(--font-label)">お名前</label>
							<input
								class="w-full bg-surface border border-outline-variant/30 px-4 py-3 text-on-surface focus:outline-none focus:border-secondary transition"
								id="name"
								name="name"
								type="text"
								placeholder="山田 太郎"
								required
								autocomplete="name"
							/>
						</div>
						<div>
							<label class="block text-xs tracking-widest uppercase text-on-surface-variant mb-2" for="email" style="font-family: var(--font-label)">メールアドレス</label>
							<input
								class="w-full bg-surface border border-outline-variant/30 px-4 py-3 text-on-surface focus:outline-none focus:border-secondary transition"
								id="email"
								name="email"
								type="email"
								placeholder="you@example.com"
								required
								autocomplete="email"
							/>
						</div>
						<div>
							<label class="block text-xs tracking-widest uppercase text-on-surface-variant mb-2" for="type" style="font-family: var(--font-label)">お問い合わせ種別</label>
							<select
								class="w-full bg-surface border border-outline-variant/30 px-4 py-3 text-on-surface focus:outline-none focus:border-secondary transition appearance-none"
								id="type"
								name="type"
							>
								<option>プロジェクト相談</option>
								<option>技術的な質問</option>
								<option>その他</option>
							</select>
						</div>
						<div>
							<label class="block text-xs tracking-widest uppercase text-on-surface-variant mb-2" for="message" style="font-family: var(--font-label)">メッセージ</label>
							<textarea
								class="w-full bg-surface border border-outline-variant/30 px-4 py-3 text-on-surface focus:outline-none focus:border-secondary transition resize-none"
								id="message"
								name="message"
								rows="5"
								placeholder="ご質問やご要望をお書きください"
								required
							></textarea>
						</div>
						<button
							class="satin-gradient text-on-primary px-8 py-3 text-sm tracking-widest uppercase w-full transition hover:opacity-90"
							type="submit"
							style="font-family: var(--font-label)"
						>
							送信する
						</button>
					</form>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
