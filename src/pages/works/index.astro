---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const works = (await getCollection('works')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Works | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-surface font-body text-on-surface overflow-x-hidden">
		<Header />
		<section class="pt-40 pb-20 px-8 bg-surface">
			<div class="max-w-7xl mx-auto mb-16">
				<span class="text-xs tracking-[0.2em] uppercase text-on-primary-container mb-4 block" style="font-family: var(--font-label)">Works</span>
				<h1 class="text-5xl text-primary" style="font-family: var(--font-headline)">実績アーカイブ</h1>
				<p class="text-on-surface-variant mt-4 text-lg max-w-2xl">設計判断、技術選定、成果までを記事形式でまとめています。</p>
			</div>
			<div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
				{
					works.map((work) => (
						<a
							href={`/works/${work.id}/`}
							class="group bg-surface-container-lowest p-8 block no-underline hover:bg-surface-container-low transition-all duration-300"
						>
							{work.data.heroImage && (
								<div class="mb-5 overflow-hidden rounded-md aspect-video">
									<img
										class="w-full h-full object-cover"
										src={work.data.heroImage}
										alt={work.data.title}
										loading="lazy"
										decoding="async"
									/>
								</div>
							)}
							<p class="text-[10px] tracking-widest uppercase text-on-primary-container mb-4" style="font-family: var(--font-label)">Case Study</p>
							<h2 class="text-xl text-primary mb-4 group-hover:text-secondary transition-colors" style="font-family: var(--font-headline)">{work.data.title}</h2>
							<p class="text-on-surface-variant text-sm leading-relaxed mb-6">{work.data.description}</p>
							{work.data.role && (
								<p class="text-[10px] tracking-widest uppercase text-on-primary-container mb-3" style="font-family: var(--font-label)">{work.data.role}</p>
							)}
							<p class="text-xs text-secondary" style="font-family: var(--font-label)">
								<FormattedDate date={work.data.pubDate} />
							</p>
						</a>
					))
				}
			</div>
		</section>
		<Footer />
	</body>
</html>