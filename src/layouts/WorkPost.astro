---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'works'>['data'];

const { title, description, pubDate, updatedDate, role, technologies, heroImage } = Astro.props;
---

<html lang="ja">
	<head>
		<BaseHead title={title} description={description} />
	</head>

	<body class="bg-surface font-body text-on-surface overflow-x-hidden">
		<Header />
		<main class="pt-24 pb-20 px-8">
			<article class="max-w-3xl mx-auto">
				{heroImage && (
					<div class="mb-10 overflow-hidden rounded-lg">
						<img class="w-full object-cover" src={heroImage} alt={title} width="1020" height="510" loading="lazy" decoding="async" />
					</div>
				)}
				<div class="bg-surface-container-lowest p-10">
					<div class="mb-8 pb-8 border-b border-outline-variant/20">
						<span class="text-[10px] tracking-widest uppercase text-on-primary-container mb-4 block" style="font-family: var(--font-label)">Work</span>
						<div class="text-sm text-secondary mb-4" style="font-family: var(--font-label)">
							<FormattedDate date={pubDate} />
							{updatedDate && (
								<span class="ml-4 italic opacity-70">
									更新: <FormattedDate date={updatedDate} />
								</span>
							)}
						</div>
						<h1 class="text-4xl text-primary leading-snug mb-4" style="font-family: var(--font-headline)">{title}</h1>
						<p class="text-on-surface-variant mb-6">{description}</p>
						{role && (
							<p class="text-xs tracking-widest uppercase text-on-primary-container mb-4" style="font-family: var(--font-label)">
								{role}
							</p>
						)}
						{technologies && technologies.length > 0 && (
							<div class="flex flex-wrap gap-3">
								{technologies.map((tech) => (
									<span class="text-xs bg-surface-container px-3 py-1 rounded-full text-secondary" style="font-family: var(--font-label)">
										#{tech}
									</span>
								))}
							</div>
						)}
					</div>
					<div class="prose">
						<slot />
					</div>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>